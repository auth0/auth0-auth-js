{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
      "build": {
        "dependsOn": ["^build"],
        "outputs": ["dist/**"],
        "outputLogs": "new-only"
      },
      "clean": {
        "dependsOn": ["^clean"],
        "outputLogs": "new-only"
      },
      "test": {
        "dependsOn": ["^test"],
        "outputLogs": "new-only"
      },
      "lint": {
        "dependsOn": [
          "^lint"
        ],
        "outputLogs": "new-only"
      }
    }
  }
